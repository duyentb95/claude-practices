# ─── insider-scanner ──────────────────────────────────────────────────────────

# HTTP port for web dashboard (default: 3235)
WEB_PORT=3235

# Copin API Key
X_API_KEY=

# Hyperliquid endpoints (defaults shown — no need to change for mainnet)
HYPER_WS_URL=wss://api.hyperliquid.xyz/ws
HYPER_API_URL=https://api.hyperliquid.xyz

# Trade size thresholds (USD)
MIN_TRADE_USD=100000      # minimum to flag as large trade (default $100k)
MEGA_TRADE_USD=1000000    # threshold for mega trade alert (default $1M)

# Lark webhook for alerts (optional — leave empty to disable)
LARK_WEBHOOK_URL=

# Rate limiting (ms between REST calls, default 1100ms = ~54 calls/min)
REST_RATE_LIMIT_MS=1100

# New account threshold — fills in last 90 days below this = "new account"
NEW_TRADER_FILLS_THRESHOLD=30