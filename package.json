{
  "name": "listener",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev:hyperliquid-bot": "nest start hyperliquid-bot --watch",
    "start:dev:hyper-rau": "nest start hyper-rau --watch",
    "start:dev:data-analytics": "nest start data-analytics --watch",
    "start:dev:insider-scanner": "nest start insider-scanner --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/listener/test/jest-e2e.json"
  },
  "dependencies": {
    "@moralisweb3/common-evm-utils": "^2.27.2",
    "@msgpack/msgpack": "^3.0.1",
    "@nestjs/axios": "3.0.2",
    "@nestjs/cache-manager": "2.2.2",
    "@nestjs/common": "^10.4.22",
    "@nestjs/core": "^10.4.22",
    "@nestjs/mongoose": "10.0.6",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/schedule": "4.0.2",
    "@nestjs/terminus": "10.2.3",
    "@sentry/node": "^7.26.0",
    "@solana/web3.js": "^1.95.8",
    "bignumber.js": "9.1.2",
    "cache-manager": "5.5.3",
    "cache-manager-redis-store": "3.0.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "crypto-js": "^4.2.0",
    "dotenv": "16.0.3",
    "ethers": "6.13.2",
    "https-proxy-agent": "^7.0.4",
    "hyperliquid-cli": "^0.0.5",
    "lossless-json": "4.0.1",
    "mongoose": "^6.13.9",
    "moralis": "^2.7.4",
    "node-telegram-bot-api": "^0.63.0",
    "redis": "4.4.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "viem": "^2.10.3",
    "web3": "4.5.0",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^7.3.1",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@share/shared(|/.*)$": "<rootDir>/libs/shared/src/$1"
    }
  }
}
